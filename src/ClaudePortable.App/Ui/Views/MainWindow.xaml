<Window x:Class="ClaudePortable.App.Ui.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudePortable" Width="960" Height="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,6" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding Status}" />
        </StatusBar>
        <TabControl Margin="8">
            <TabItem Header="Status">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Backup now" Command="{Binding BackupNowCommand}" Padding="12,6" Margin="0,0,8,8" />
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,6" Margin="0,0,8,8" />
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Backups}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetFolder}" Width="2*" />
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="3*" />
                            <DataGridTextColumn Header="Bytes" Binding="{Binding SizeBytes, StringFormat=N0}" Width="*" />
                            <DataGridTextColumn Header="Tier" Binding="{Binding Manifest.RetentionTier}" Width="*" />
                            <DataGridTextColumn Header="Created" Binding="{Binding Manifest.CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="1.5*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Targets">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Add folder..." Command="{Binding AddTargetCommand}" Padding="12,6" Margin="0,0,8,8" />
                        <Button Content="Remove selected" Command="{Binding RemoveTargetCommand}" Padding="12,6" Margin="0,0,8,8" />
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Discovery">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Claude paths" FontWeight="Bold" Margin="0,0,0,4" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ClaudePaths}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*" />
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="3*" />
                            <DataGridCheckBoxColumn Header="Exists" Binding="{Binding Exists}" Width="Auto" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" Text="Sync clients" FontWeight="Bold" Margin="0,12,0,4" />
                    <DataGrid Grid.Row="3" ItemsSource="{Binding SyncClients}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="3*" />
                            <DataGridCheckBoxColumn Header="Avail" Binding="{Binding IsAvailable}" Width="Auto" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Restore">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                        Select a backup below and click Restore. Existing Claude data will be moved aside (not deleted) before the restore runs.
                    </TextBlock>
                    <DockPanel Grid.Row="1">
                        <Button Content="Restore selected" DockPanel.Dock="Bottom" Command="{Binding RestoreCommand}" Padding="12,6" Margin="0,8,0,0" HorizontalAlignment="Left" />
                        <DataGrid ItemsSource="{Binding Backups}" SelectedItem="{Binding SelectedBackup}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="3*" />
                                <DataGridTextColumn Header="Tier" Binding="{Binding Manifest.RetentionTier}" Width="*" />
                                <DataGridTextColumn Header="Created" Binding="{Binding Manifest.CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="1.5*" />
                                <DataGridTextColumn Header="Hostname" Binding="{Binding Manifest.Hostname}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <ListBox ItemsSource="{Binding LogEntries}" Margin="8" FontFamily="Consolas" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
