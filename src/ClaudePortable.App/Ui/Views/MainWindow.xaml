<Window x:Class="ClaudePortable.App.Ui.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudePortable"
        Width="1120" Height="720"
        MinWidth="820" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#262624"
        Foreground="#FFFFFF"
        FontFamily="Segoe UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Grayscale">
    <DockPanel Background="#262624">

        <!-- Status bar at the very bottom -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Left">
                <TextBlock Text="{Binding Status}" />
            </StatusBarItem>
            <StatusBarItem DockPanel.Dock="Right" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisible}}" Margin="16,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ProgressMessage}" Foreground="#D6D3C9" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <ProgressBar Width="220" Height="6"
                                 Value="{Binding ProgressValue, Mode=OneWay}"
                                 Minimum="0" Maximum="1"
                                 IsIndeterminate="{Binding ProgressIsIndeterminate}"
                                 Foreground="#D97757" Background="#33322F" BorderThickness="0" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Sidebar -->
        <Border DockPanel.Dock="Left" Width="240" Background="{DynamicResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Margin="20,24,20,0">
                        <Rectangle Width="22" Height="22" RadiusX="5" RadiusY="5" Fill="{DynamicResource AccentBrush}" />
                        <TextBlock Text="ClaudePortable" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Style="{DynamicResource SidebarVersion}" Text="{Binding AppVersionLabel}" />
                </StackPanel>

                <!-- Nav -->
                <ListBox x:Name="Nav" Grid.Row="1"
                         Style="{DynamicResource SidebarNav}"
                         ItemContainerStyle="{DynamicResource NavItem}"
                         SelectedIndex="0">
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource NavGlyph}" Text="&#xE9D9;" />
                            <TextBlock Style="{DynamicResource NavLabel}" Text="Status" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource NavGlyph}" Text="&#xE8B7;" />
                            <TextBlock Style="{DynamicResource NavLabel}" Text="Targets" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource NavGlyph}" Text="&#xE721;" />
                            <TextBlock Style="{DynamicResource NavLabel}" Text="Discovery" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource NavGlyph}" Text="&#xE7A7;" />
                            <TextBlock Style="{DynamicResource NavLabel}" Text="Restore" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource NavGlyph}" Text="&#xE9F9;" />
                            <TextBlock Style="{DynamicResource NavLabel}" Text="Logs" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- Footer: always-visible primary action -->
                <StackPanel Grid.Row="2" Margin="16,8,16,20">
                    <Button Content="Backup now"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding BackupNowCommand}"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Subtle divider between sidebar and content -->
        <Border DockPanel.Dock="Left" Width="1" Background="{DynamicResource BorderBrush}" />

        <!-- Main content area, driven by sidebar -->
        <TabControl Style="{DynamicResource HiddenTabs}" SelectedIndex="{Binding ElementName=Nav, Path=SelectedIndex}">

            <!-- 1. Status / Dashboard -->
            <TabItem>
                <Grid Margin="32,24,32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{DynamicResource H1}" Text="Status" />
                    <TextBlock Style="{DynamicResource Caption}" Text="A snapshot of your Claude backups across all configured folders." Margin="0,0,0,20" Grid.Row="1" />

                    <!-- Summary cards -->
                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,20">
                        <Border Style="{DynamicResource Card}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Style="{DynamicResource Caption}" Text="BACKUPS" />
                                <TextBlock Text="{Binding Backups.Count}" FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0" />
                                <TextBlock Style="{DynamicResource Muted}" Text="across all targets" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource Card}" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Style="{DynamicResource Caption}" Text="TARGETS" />
                                <TextBlock Text="{Binding Targets.Count}" FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0" />
                                <TextBlock Style="{DynamicResource Muted}" Text="folders configured" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource Card}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Style="{DynamicResource Caption}" Text="DISCOVERED" />
                                <TextBlock Text="{Binding ClaudePaths.Count}" FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0" />
                                <TextBlock Style="{DynamicResource Muted}" Text="Claude paths found" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Style="{DynamicResource H2}" Text="Recent backups" VerticalAlignment="Center" />
                        <Button Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                HorizontalAlignment="Right" Margin="16,0,0,8" />
                    </StackPanel>

                    <DataGrid Grid.Row="4"
                              ItemsSource="{Binding Backups}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TIER" Binding="{Binding Manifest.RetentionTier}" Width="Auto" />
                            <DataGridTextColumn Header="CREATED" Binding="{Binding Manifest.CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="Auto" />
                            <DataGridTextColumn Header="HOSTNAME" Binding="{Binding Manifest.Hostname}" Width="Auto" />
                            <DataGridTextColumn Header="SIZE" Binding="{Binding SizeBytes, StringFormat=N0}" Width="Auto" />
                            <DataGridTextColumn Header="FILE" Binding="{Binding FileName}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- 2. Targets -->
            <TabItem>
                <Grid Margin="32,24,32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{DynamicResource H1}" Text="Targets" />
                    <TextBlock Style="{DynamicResource Caption}" Text="Folders where ClaudePortable writes backup ZIPs. Let OneDrive, Google Drive, Dropbox, or your own sync client handle the upload." Margin="0,0,0,20" Grid.Row="1" TextWrapping="Wrap" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Add folder"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding AddTargetCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Remove selected"
                                Command="{Binding RemoveTargetCommand}" />
                    </StackPanel>

                    <Border Style="{DynamicResource Card}" Padding="0" Grid.Row="3">
                        <DataGrid ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PATH" Binding="{Binding Path}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 3. Discovery -->
            <TabItem>
                <Grid Margin="32,24,32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{DynamicResource H1}" Text="Discovery" />
                    <TextBlock Style="{DynamicResource Caption}" Text="What ClaudePortable found on this machine. Paths that do not exist are skipped during backup." Margin="0,0,0,20" Grid.Row="1" TextWrapping="Wrap" />

                    <TextBlock Style="{DynamicResource H2}" Text="Claude paths" Grid.Row="2" Margin="0,0,0,8" />
                    <Border Style="{DynamicResource Card}" Padding="0" Grid.Row="3">
                        <DataGrid ItemsSource="{Binding ClaudePaths}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="KEY" Binding="{Binding Key}" Width="Auto" />
                                <DataGridTextColumn Header="PATH" Binding="{Binding Path}" Width="*" />
                                <DataGridCheckBoxColumn Header="EXISTS" Binding="{Binding Exists}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <TextBlock Style="{DynamicResource H2}" Text="Sync clients" Grid.Row="4" Margin="0,20,0,8" />
                    <Border Style="{DynamicResource Card}" Padding="0" Grid.Row="5">
                        <DataGrid ItemsSource="{Binding SyncClients}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="Auto" />
                                <DataGridTextColumn Header="PATH" Binding="{Binding Path}" Width="*" />
                                <DataGridCheckBoxColumn Header="AVAIL" Binding="{Binding IsAvailable}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 4. Restore -->
            <TabItem>
                <Grid Margin="32,24,32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{DynamicResource H1}" Text="Restore" />
                    <TextBlock Style="{DynamicResource Caption}" TextWrapping="Wrap" Margin="0,0,0,20" Grid.Row="1">
                        Select a snapshot from a configured target or browse to any
                        <Run FontFamily="{DynamicResource MonoFont}">claude-backup_*.zip</Run> on disk
                        (handy when you moved to another machine). ClaudePortable moves the current
                        Claude data aside to
                        <Run FontFamily="{DynamicResource MonoFont}">&lt;folder&gt;_backup_&lt;timestamp&gt;</Run>
                        before restoring — nothing is deleted.
                    </TextBlock>

                    <TextBlock Style="{DynamicResource H2}" Text="Available snapshots" Grid.Row="2" />

                    <Border Style="{DynamicResource Card}" Padding="0" Grid.Row="3">
                        <DataGrid ItemsSource="{Binding Backups}" SelectedItem="{Binding SelectedBackup}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STATUS" Binding="{Binding StatusLabel}" Width="Auto" />
                                <DataGridTextColumn Header="TIER" Binding="{Binding Manifest.RetentionTier}" Width="Auto" />
                                <DataGridTextColumn Header="CREATED" Binding="{Binding Manifest.CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="Auto" />
                                <DataGridTextColumn Header="HOSTNAME" Binding="{Binding Manifest.Hostname}" Width="Auto" />
                                <DataGridTextColumn Header="FILE" Binding="{Binding FileName}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0" Grid.Row="4">
                        <Button Content="Restore selected snapshot"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding RestoreCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Restore from file..."
                                Command="{Binding RestoreFromFileCommand}" />
                    </StackPanel>

                    <Expander Grid.Row="5" Margin="0,16,0,0"
                              Foreground="#D6D3C9"
                              Header="Advanced options"
                              FontSize="13"
                              FontWeight="SemiBold">
                        <Border Style="{DynamicResource Card}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Style="{DynamicResource Caption}" TextWrapping="Wrap" Margin="0,0,0,12">
                                    Override where the restore writes files. Use this when the backup was taken
                                    under a different Windows user name (e.g.
                                    <Run FontFamily="{DynamicResource MonoFont}">sascha</Run> on the workstation,
                                    <Run FontFamily="{DynamicResource MonoFont}">sasch</Run> on the laptop). All
                                    sub-paths (<Run FontFamily="{DynamicResource MonoFont}">AppData\Roaming</Run>,
                                    <Run FontFamily="{DynamicResource MonoFont}">AppData\Local</Run>,
                                    <Run FontFamily="{DynamicResource MonoFont}">.claude</Run>,
                                    <Run FontFamily="{DynamicResource MonoFont}">.cowork</Run>) are derived from
                                    this root. Leave blank to use
                                    <Run FontFamily="{DynamicResource MonoFont}">%USERPROFILE%</Run>.
                                </TextBlock>

                                <TextBlock Text="Target user profile" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="#D6D3C9" />
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="Browse..."
                                            Command="{Binding PickTargetProfileCommand}"
                                            Margin="8,0,0,0" />
                                    <TextBox Text="{Binding TargetUserProfileOverride, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#1A1917"
                                             Foreground="#FFFFFF"
                                             CaretBrush="#FFFFFF"
                                             BorderBrush="#4A4944"
                                             BorderThickness="1"
                                             Padding="10,6"
                                             FontFamily="{DynamicResource MonoFont}" />
                                </DockPanel>

                                <CheckBox IsChecked="{Binding IgnoreVersionMismatch}"
                                          Foreground="#D6D3C9"
                                          Margin="0,0,0,8">
                                    <TextBlock TextWrapping="Wrap">
                                        Ignore Claude Desktop version mismatch
                                        <Run Foreground="#B5B2A8" FontSize="12" FontStyle="Italic">(skip the major-version block; chat-history schema may differ)</Run>
                                    </TextBlock>
                                </CheckBox>
                            </StackPanel>
                        </Border>
                    </Expander>
                </Grid>
            </TabItem>

            <!-- 5. Logs -->
            <TabItem>
                <Grid Margin="32,24,32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{DynamicResource H1}" Text="Logs" />
                    <TextBlock Style="{DynamicResource Caption}" Text="Most recent 500 lines from this session. Logs persist in memory only — restart clears them." Margin="0,0,0,20" Grid.Row="1" />

                    <Border Style="{DynamicResource Card}" Grid.Row="2">
                        <ListBox ItemsSource="{Binding LogEntries}" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

    </DockPanel>
</Window>
